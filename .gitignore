# Local env (secrets / per-host config)
.env
# Per-app secrets (each app ships a *.env.example; the real *.env stays local).
# Covers apps/<app>/*.env and nested ones like apps/<app>/postgres/provision.env.
apps/**/*.env

# NGINX Proxy Manager runtime data + certs (generated by the container, never commit).
core/nginx-proxy-manager/data/
core/nginx-proxy-manager/letsencrypt/

# Dashboards fetched by scripts/fetch-dashboards.sh are provisioned at runtime;
# uncomment to keep them out of git and rely on the fetch script instead.
# core/grafana/dashboards/*.json
