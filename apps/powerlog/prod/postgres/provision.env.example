# powerlog's database declaration for the SHARED Postgres provisioner
# (pi-infra core/postgres). Copy to provision.env (gitignored). The core
# provisioner reads apps/powerlog/postgres/provision.env on every `up` and
# idempotently ensures this role + database + grants.
#
# IMPORTANT:
#  - Use a strong, ALPHANUMERIC password (it's interpolated into SQL — avoid
#    $ ` ' " and spaces).
#  - APP_DB_PASSWORD MUST equal the password in powerlog.env's DATABASE_URL and
#    MIGRATIONS_DATABASE_URL (single source of truth).
APP_DB=powerlog
APP_DB_USER=powerlog
APP_DB_PASSWORD=__set_a_strong_alphanumeric_password__
