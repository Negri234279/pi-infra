# powerlog — Pi/prod stack env. Copy to powerlog.env (gitignored) and fill in.
# Single env_file for the whole stack (compose reads it via env_file:).
# Because compose does NOT interpolate env_file values into the compose file,
# connection strings are given here as full URLs (host = service DNS name).

# ── Database (SHARED core Postgres) ──────────────────────────
# powerlog's role + db are provisioned on the shared Postgres from
# postgres/provision.env — APP_DB_PASSWORD there MUST equal the password used in
# the two URLs below (single source of truth).
#
# Runtime → PgBouncer (transaction pooling). Migrations → Postgres DIRECT
# (the migrator holds a session-level advisory lock, incompatible with the pooler).
DATABASE_URL="postgresql://powerlog:__same_as_provision_APP_DB_PASSWORD__@pgbouncer:6432/powerlog"
MIGRATIONS_DATABASE_URL="postgresql://powerlog:__same_as_provision_APP_DB_PASSWORD__@postgres:5432/powerlog"

# Inject the PEMs from a secret manager (inline wins). Or mount key files and
# point *_PATH at them (defaults: jwt.private.pem / jwt.public.pem).
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt.private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt.public.pem
JWT_ISSUER="powerlog"
JWT_AUDIENCE="powerlog-web"
JWT_EXPIRES_IN="15m"
REFRESH_EXPIRES_IN="30d"

# Cookies — keep Secure on (HTTPS via nginx-proxy-manager). Set COOKIE_DOMAIN
# to your parent domain so the cookie is shared across api/web subdomains.
AUTH_COOKIE_NAME="pl_at"
REFRESH_COOKIE_NAME="pl_rt"
COOKIE_SECURE="true"
COOKIE_DOMAIN="powerlog.negri.es"
WEB_ORIGIN="https://powerlog.negri.es"

# Google OAuth — inject the secret from a secret manager.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="https://api.powerlog.es/auth/google/callback"

# Mail — prod uses Resend (inject RESEND_API_KEY from a secret manager).
MAIL_TRANSPORT="resend"
MAIL_FROM="PowerLog <no-reply@powerlog.negri.es>"
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
EMAIL_VERIFICATION_TTL="24h"
PASSWORD_RESET_TTL="1h"

# Avatars — Cloudflare R2 (S3-compatible). Inject keys from a secret manager.
AVATAR_STORAGE="r2"
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="powerlog-prod"
R2_PUBLIC_URL="https://avatar.powerlog.negri.es"