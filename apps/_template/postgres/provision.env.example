# <myapp>'s database declaration for the SHARED Postgres provisioner.
# Copy to provision.env (gitignored by apps/**/*.env). The core provisioner reads
# apps/<myapp>/postgres/provision.env on every `up` and idempotently ensures this
# role + database + grants on the shared Postgres.
#
# IMPORTANT:
#  - Strong, ALPHANUMERIC password (it's interpolated into SQL — avoid $ ` ' " spaces).
#  - APP_DB_PASSWORD must equal the password your app uses in its DATABASE_URL
#    (runtime → pgbouncer:6432/<APP_DB>) and migration URL (→ postgres:5432/<APP_DB>).
APP_DB=myapp
APP_DB_USER=myapp
APP_DB_PASSWORD=__set_a_strong_alphanumeric_password__
