# Central observability stack — copy to `.env` and adjust.
#   cp .env.example .env

# --- Grafana ---
# Initial admin credentials (change the password before exposing Grafana).
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# --- Prometheus (infra) retention ---
# Keep storage bounded so cAdvisor's high series count doesn't wear the Pi's
# disk. Whichever limit is hit first wins.
PROM_RETENTION_TIME=15d
PROM_RETENTION_SIZE=2GB

# --- NGINX Proxy Manager ---
# NPM runs in the core stack with embedded SQLite (no DB env needed). On first run,
# log in to the admin UI at http://<pi>:81 with the default credentials
#   admin@example.com / changeme
# NPM forces you to change them immediately. The proxy listens on :80 and :443.

# --- Shared Postgres ---
# One Postgres for every app. The superuser password protects the whole cluster;
# the provisioner uses it to create per-app roles/databases. The exporter role is
# least-privilege (pg_monitor); pgbouncer_auth backs PgBouncer's auth_query.
# Keep these alphanumeric (they're interpolated into SQL by the provisioner).
POSTGRES_SUPERUSER_PASSWORD=changeme_super
PG_EXPORTER_USER=postgres_exporter
PG_EXPORTER_PASSWORD=changeme_exporter
PGBOUNCER_AUTH_PASSWORD=changeme_pgbouncer

# --- Alerting (Discord) ---
# Discord channel webhook (Server Settings → Integrations → Webhooks → Copy URL).
# Read at startup by the alertmanager-init container into a secret file; never
# committed. Leave empty to disable Discord notifications.
DISCORD_WEBHOOK_URL=
